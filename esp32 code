  display.clearDisplay();

  display.setCursor(0, 0);
  display.println("SMART BLIND STICK");

  display.setCursor(0, 20);
  display.println("WiFi Connected");

  display.setCursor(0, 35);
  display.println(WiFi.localIP());

  display.display();

  delay(3000);
}

// =======================
// Loop
// =======================

void loop()
{
  while (GPS.available())
{
  gps.encode(GPS.read());
}

if (gps.location.isUpdated())
{
  latitude = gps.location.lat();
  longitude = gps.location.lng();

  Serial.print("Latitude: ");
  Serial.println(latitude, 6);

  Serial.print("Longitude: ");
  Serial.println(longitude, 6);

  Serial.print("Satellites: ");
  Serial.println(gps.satellites.value());

  Serial.println("----------------");
}
  reconnectWiFi();

  float obsDistance = getDistance(OBS_TRIG, OBS_ECHO);

  delay(50);

  float depDistance = getDistance(DEP_TRIG, DEP_ECHO);

  Serial.print("OBS: ");
  Serial.print(obsDistance);
  Serial.print(" cm   ");

  Serial.print("DEP: ");
  Serial.print(depDistance);
  Serial.println(" cm");

  String sensorStatus = "NO DETECTION";

  bool obsActive =
    (obsDistance > 0 &&
     obsDistance < OBS_FAR);

  bool depActive =
    (depDistance > DEP_THRESHOLD &&
     depDistance != -1);

  if (obsActive && depActive)
    sensorStatus = "OBS+DEP ACTIVE";
  else if (obsActive)
    sensorStatus = "OBS ACTIVE";
  else if (depActive)
    sensorStatus = "DEP ACTIVE";

  // =======================
  // OLED Display
  // =======================

  display.clearDisplay();

  display.setTextSize(1);

  display.setCursor(0, 0);
  display.println("SMART BLIND STICK");

  display.setCursor(0, 15);
  display.print("OBS: ");

  if (obsDistance == -1)
    display.print("No Echo");
  else
  {
    display.print(obsDistance, 1);
    display.print(" cm");
  }

  display.setCursor(0, 30);
  display.print("DEP: ");

  if (depDistance == -1)
    display.print("No Echo");
  else
  {
    display.print(depDistance, 1);
    display.print(" cm");
  }

  display.setCursor(0, 50);
  display.print(sensorStatus);

  display.display();

  // =======================
  // Upload Every 10 Seconds
  // =======================

  if (millis() - lastUpload > 10000)
  {
    sendToSupabase(obsDistance);
    lastUpload = millis();
  }


// =======================
// Buzzer + Vibration Logic
// =======================

if (depActive)
{
  // Pit / Stairs detected

  digitalWrite(BUZZER, HIGH);
  digitalWrite(VIBRATION, HIGH);
  delay(100);

  digitalWrite(BUZZER, LOW);
  digitalWrite(VIBRATION, LOW);
  delay(100);

  digitalWrite(BUZZER, HIGH);
  digitalWrite(VIBRATION, HIGH);
  delay(100);

  digitalWrite(BUZZER, LOW);
  digitalWrite(VIBRATION, LOW);
  delay(300);
}
else if (obsDistance > 0)
{
  if (obsDistance < OBS_CLOSE)
  {
    // Very close obstacle

    digitalWrite(BUZZER, HIGH);
    digitalWrite(VIBRATION, HIGH);
    delay(50);

    digitalWrite(BUZZER, LOW);
    digitalWrite(VIBRATION, LOW);
    delay(50);
  }
  else if (obsDistance < OBS_MEDIUM)
  {
    // Medium obstacle

    digitalWrite(BUZZER, HIGH);
    digitalWrite(VIBRATION, HIGH);
    delay(100);

    digitalWrite(BUZZER, LOW);
    digitalWrite(VIBRATION, LOW);
    delay(150);
  }
  else if (obsDistance < OBS_FAR)
  {
    // Far obstacle

    digitalWrite(BUZZER, HIGH);
    digitalWrite(VIBRATION, HIGH);
    delay(100);

    digitalWrite(BUZZER, LOW);
    digitalWrite(VIBRATION, LOW);
    delay(400);
  }
  else
  {
    digitalWrite(BUZZER, LOW);
    digitalWrite(VIBRATION, LOW);
    delay(100);
  }
}
else
{
  digitalWrite(BUZZER, LOW);
  digitalWrite(VIBRATION, LOW);
  delay(100);
}
}
