#define OBS_MEDIUM 50
#define OBS_FAR 100

#define DEP_THRESHOLD 70

// =======================
// Distance Function
// =======================

float getDistance(int trigPin, int echoPin)
{
  digitalWrite(trigPin, LOW);
  delayMicroseconds(3);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);

  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 30000);

  if (duration == 0)
    return -1;

  float distance = duration * 0.0343 / 2.0;

  if (distance < 2 || distance > 400)
    return -1;

  return distance;
}

// =======================
// WiFi Reconnect
// =======================

void reconnectWiFi()
{
  if (WiFi.status() == WL_CONNECTED)
    return;

  Serial.println("WiFi Lost. Reconnecting...");

  WiFi.begin(ssid, password);

  int attempts = 0;

  while (WiFi.status() != WL_CONNECTED && attempts < 20)
  {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED)
  {
    Serial.println();
    Serial.println("WiFi Reconnected");
  }
}

// =======================
// Supabase Upload
// =======================

void sendToSupabase(float obstacleDistance)
{
  if (WiFi.status() != WL_CONNECTED)
  {
    Serial.println("WiFi Not Connected");
    return;
  }

  HTTPClient http;

  http.begin(supabaseUrl);

  http.addHeader("Content-Type", "application/json");
  http.addHeader("apikey", apiKey);
  http.addHeader("Authorization", "Bearer " + apiKey);
  http.addHeader("Prefer", "return=minimal");

String payload =
  "{\"latitude\":" + String(latitude, 6) +
  ",\"longitude\":" + String(longitude, 6) +
  ",\"obstacle_distance\":" +
  String((int)obstacleDistance) +
  "}";

  int httpCode = http.POST(payload);

  Serial.print("Supabase Response: ");
  Serial.println(httpCode);

  http.end();
}

// =======================
// Setup
// =======================

void setup()
{
  Serial.begin(115200);

  GPS.begin(4800, SERIAL_8N1, 16, 17);

  Serial.println("GPS Started");

  pinMode(OBS_TRIG, OUTPUT);
  pinMode(OBS_ECHO, INPUT);

  pinMode(DEP_TRIG, OUTPUT);
  pinMode(DEP_ECHO, INPUT);

  pinMode(BUZZER, OUTPUT);

  pinMode(VIBRATION, OUTPUT);
  digitalWrite(VIBRATION, LOW);

  Wire.begin(21, 22);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C))
  {
    Serial.println("OLED Not Found");
    while (1);
  }

  display.clearDisplay();
  display.setTextColor(WHITE);

  display.setTextSize(2);
  display.setCursor(5, 20);
  display.println("SMART");
  display.display();

  delay(1500);

  // =======================
  // Connecting WiFi Screen
  // =======================

  display.clearDisplay();
  display.setTextSize(1);

  display.setCursor(0, 0);
  display.println("SMART BLIND STICK");

  display.setCursor(0, 25);
  display.println("Connecting WiFi...");
  display.display();

  Serial.println("Connecting WiFi...");

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED)
